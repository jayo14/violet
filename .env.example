# LLM Provider (OpenRouter, Nvidia NIM, Groq)
LLM_PROVIDER=openrouter
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=meta-llama/llama-3.3-8b-instruct:free

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# Composio (tool integration platform)
COMPOSIO_API_KEY=
COMPOSIO_BASE_URL=https://api.composio.dev

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# GitHub OAuth2
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5173/auth/github/callback

# Session
SESSION_SECRET=violet-session-secret-change-in-prod

# Base URL (used for OAuth redirects and Composio callbacks)
BASE_URL=http://localhost:5173

# Appwrite Configuration (Required for authentication and data storage)
# Get these from your Appwrite Project Settings
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=
VITE_APPWRITE_DATABASE_ID=violet-db
